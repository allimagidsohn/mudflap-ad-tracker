{
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:server": "node --import=dotenv/config src/server/index.js",
    "dev:all": "concurrently -k \"pnpm dev\" \"pnpm dev:server\"",
    "build": "vite build && pnpm run build:server",
    "build:server": "esbuild src/server/index.js --bundle --platform=node --format=esm --outfile=dist/server.js --external:pg",
    "start": "node --import=dotenv/config dist/server.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "dotenv": "^17.2.3",
    "hono": "^4.11.7",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.2",
    "vite": "^8.0.11"
  }
}
